@model AdminProductDetailsViewModel

@{
    ViewData["Title"] = $"Product Details - {Model.Name}";
    var effectivePrice = Model.DiscountedPrice > 0 ? Model.DiscountedPrice : Model.Price;
    var hasDiscount = Model.DiscountedPrice > 0 && Model.DiscountedPrice < Model.Price;
    var hasPromotion = !string.IsNullOrWhiteSpace(Model.PromotionName);
    var imageGallery = Model.Images.ToList();
    var hasImages = imageGallery.Any();
    var stockState = Model.QuantityInStock switch
    {
        0 => "Out of stock",
        <= 5 => "Low stock",
        _ => "In stock"
    };
    var stockBadgeClass = Model.QuantityInStock switch
    {
        0 => "badge-stock-empty",
        <= 5 => "badge-stock-low",
        _ => "badge-stock-good"
    };
}

<style>
    .admin-product-details-page {
        --admin-bg: linear-gradient(135deg, #f6f7fb 0%, #eef4ff 100%);
        --admin-surface: rgba(255, 255, 255, 0.96);
        --admin-surface-strong: #ffffff;
        --admin-border: #dbe3f0;
        --admin-text: #1f2937;
        --admin-muted: #6b7280;
        --admin-accent: #0f766e;
        --admin-accent-soft: #ccfbf1;
        --admin-warning: #b45309;
        --admin-warning-soft: #fef3c7;
        --admin-danger: #b91c1c;
        --admin-danger-soft: #fee2e2;
        --admin-success: #166534;
        --admin-success-soft: #dcfce7;
        --admin-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
        color: var(--admin-text);
    }

    .admin-product-details-shell {
        background: var(--admin-bg);
        border: 1px solid var(--admin-border);
        border-radius: 28px;
        padding: 28px;
        box-shadow: var(--admin-shadow);
    }

    .admin-product-details-topbar {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 24px;
        margin-bottom: 24px;
    }

    .admin-product-details-topbar h1 {
        font-size: 2.1rem;
        margin: 0 0 8px;
    }

    .admin-product-details-topbar p {
        margin: 0;
        color: var(--admin-muted);
        max-width: 720px;
    }

    .admin-product-details-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .btn-admin {
        border: none;
        border-radius: 12px;
        padding: 10px 14px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-admin-secondary {
        background: #e2e8f0;
        color: #0f172a;
    }

    .admin-overview-grid {
        display: grid;
        grid-template-columns: 1.35fr 0.95fr;
        gap: 20px;
        margin-bottom: 20px;
    }

    .admin-panel {
        background: var(--admin-surface);
        border: 1px solid var(--admin-border);
        border-radius: 24px;
        padding: 24px;
    }

    .admin-panel h2 {
        margin: 0 0 18px;
        font-size: 1.2rem;
    }

    .admin-product-hero {
        display: grid;
        grid-template-columns: minmax(280px, 360px) minmax(0, 1fr);
        gap: 24px;
        align-items: start;
    }

    .admin-gallery-panel {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .admin-gallery-frame {
        position: relative;
        overflow: hidden;
        border-radius: 22px;
        border: 1px solid var(--admin-border);
        background:
            radial-gradient(circle at top, rgba(14, 116, 144, 0.16), transparent 40%),
            linear-gradient(135deg, #f8fafc 0%, #dbeafe 100%);
        aspect-ratio: 1 / 1;
    }

    .admin-gallery-frame img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .admin-gallery-placeholder {
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 24px;
        color: var(--admin-muted);
        font-weight: 700;
        line-height: 1.6;
    }

    .admin-gallery-thumbs {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(72px, 1fr));
        gap: 10px;
    }

    .admin-gallery-thumb {
        border: 1px solid var(--admin-border);
        border-radius: 14px;
        overflow: hidden;
        background: #fff;
        aspect-ratio: 1 / 1;
    }

    .admin-gallery-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .admin-product-content {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .admin-kicker-row {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .admin-kicker {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 0.45rem 0.8rem;
        border-radius: 999px;
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.03em;
    }

    .badge-sku {
        background: #e0f2fe;
        color: #075985;
    }

    .badge-category {
        background: #ede9fe;
        color: #5b21b6;
    }

    .badge-promo {
        background: var(--admin-accent-soft);
        color: var(--admin-accent);
    }

    .badge-stock-empty,
    .badge-stock-low,
    .badge-stock-good {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.42rem 0.75rem;
        border-radius: 999px;
        font-size: 0.8rem;
        font-weight: 700;
    }

    .badge-stock-empty {
        background: var(--admin-danger-soft);
        color: var(--admin-danger);
    }

    .badge-stock-low {
        background: var(--admin-warning-soft);
        color: var(--admin-warning);
    }

    .badge-stock-good {
        background: var(--admin-success-soft);
        color: var(--admin-success);
    }

    .admin-product-name {
        margin: 0;
        font-size: 2.35rem;
        line-height: 1.05;
    }

    .admin-product-description {
        margin: 0;
        color: var(--admin-muted);
        font-size: 1rem;
        line-height: 1.7;
        white-space: pre-line;
    }

    .admin-pricing-card {
        background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 100%);
        color: #fff;
        border-radius: 22px;
        padding: 22px;
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .admin-pricing-card span {
        opacity: 0.78;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.78rem;
    }

    .admin-price-row {
        display: flex;
        align-items: end;
        gap: 12px;
        flex-wrap: wrap;
    }

    .admin-price-current {
        font-size: 2.4rem;
        line-height: 1;
        font-weight: 800;
    }

    .admin-price-original {
        opacity: 0.7;
        font-size: 1rem;
    }

    .admin-metrics-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
    }

    .admin-metric-card {
        background: var(--admin-surface-strong);
        border: 1px solid var(--admin-border);
        border-radius: 18px;
        padding: 18px;
    }

    .admin-metric-card span {
        display: block;
        color: var(--admin-muted);
        font-size: 0.84rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 8px;
    }

    .admin-metric-card strong {
        font-size: 1.6rem;
        line-height: 1.1;
    }

    .admin-detail-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 20px;
    }

    .admin-detail-list {
        display: grid;
        grid-template-columns: minmax(120px, 160px) 1fr;
        gap: 14px 18px;
        margin: 0;
    }

    .admin-detail-list dt {
        color: var(--admin-muted);
        font-weight: 700;
    }

    .admin-detail-list dd {
        margin: 0;
        font-weight: 600;
        word-break: break-word;
    }

    .admin-note {
        margin: 0;
        color: var(--admin-muted);
        line-height: 1.7;
    }

    @@media (max-width: 991.98px) {
        .admin-overview-grid,
        .admin-detail-grid,
        .admin-product-hero {
            grid-template-columns: 1fr;
        }

        .admin-product-details-topbar {
            flex-direction: column;
        }
    }

    @@media (max-width: 767.98px) {
        .admin-product-details-shell {
            padding: 18px;
            border-radius: 20px;
        }

        .admin-panel {
            padding: 18px;
            border-radius: 18px;
        }

        .admin-product-name {
            font-size: 1.8rem;
        }

        .admin-metrics-grid,
        .admin-detail-list {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="admin-product-details-page">
    <div class="admin-product-details-shell">
        <div class="admin-product-details-topbar">
            <div>
                <h1>Product Details</h1>
                <p>Review the selected inventory item, confirm pricing and stock status, and verify how it is currently classified inside the catalog.</p>
            </div>

            <div class="admin-product-details-actions">
                <a class="btn-admin btn-admin-secondary" asp-area="Admin" asp-controller="Products" asp-action="Index">Back to Products</a>
            </div>
        </div>

        <section class="admin-overview-grid">
            <article class="admin-panel admin-product-hero">
                <div class="admin-gallery-panel">
                    <div class="admin-gallery-frame">
                        @if (hasImages)
                        {
                            <img src="data:image/png;base64,@Convert.ToBase64String(imageGallery[0].bytes)" alt="@Model.Name primary image" />
                        }
                        else
                        {
                            <div class="admin-gallery-placeholder">
                                <div>
                                    <div>No product image available</div>
                                    <div>Upload one later to improve admin review and storefront presentation.</div>
                                </div>
                            </div>
                        }
                    </div>

                    @if (imageGallery.Count > 1)
                    {
                        <div class="admin-gallery-thumbs">
                            @foreach (var image in imageGallery)
                            {
                                <div class="admin-gallery-thumb">
                                    <img src="data:image/png;base64,@Convert.ToBase64String(image.bytes)" alt="@Model.Name gallery image" />
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="admin-product-content">
                    <div class="admin-kicker-row">
                        <span class="admin-kicker badge-sku">SKU: @Model.SKU</span>
                        <span class="admin-kicker badge-category">@Model.CategoryName</span>
                        @if (hasPromotion)
                        {
                            <span class="admin-kicker badge-promo">Promo: @Model.PromotionName</span>
                        }
                    </div>

                    <div>
                        <h2 class="admin-product-name">@Model.Name</h2>
                    </div>

                    <p class="admin-product-description">@Model.Description</p>

                    <div class="admin-pricing-card">
                        <span>Current Sell Price</span>
                        <div class="admin-price-row">
                            <strong class="admin-price-current">$@effectivePrice.ToString("F2")</strong>
                            @if (hasDiscount)
                            {
                                <span class="admin-price-original"><s>$@Model.Price.ToString("F2")</s></span>
                            }
                        </div>
                    </div>
                </div>
            </article>

            <aside class="admin-panel">
                <h2>Status Snapshot</h2>

                <div class="admin-metrics-grid">
                    <div class="admin-metric-card">
                        <span>Inventory</span>
                        <strong>@Model.QuantityInStock</strong>
                    </div>

                    <div class="admin-metric-card">
                        <span>Stock State</span>
                        <div class="@stockBadgeClass">@stockState</div>
                    </div>

                    <div class="admin-metric-card">
                        <span>Promotion</span>
                        <strong>@(hasPromotion ? "Active" : "None")</strong>
                    </div>

                    <div class="admin-metric-card">
                        <span>Created</span>
                        <strong>@Model.CreatedOnDate.ToString("dd MMM yyyy")</strong>
                    </div>
                </div>
            </aside>
        </section>

        <section class="admin-detail-grid">
            <article class="admin-panel">
                <h2>Catalog Information</h2>
                <dl class="admin-detail-list">
                    <dt>Product Item ID</dt>
                    <dd>@Model.ProductItemId</dd>

                    <dt>Product ID</dt>
                    <dd>@Model.ProductId</dd>

                    <dt>Category</dt>
                    <dd>@Model.CategoryName</dd>

                    <dt>Promotion</dt>
                    <dd>@(hasPromotion ? Model.PromotionName : "No active promotion")</dd>

                    <dt>Base Price</dt>
                    <dd>$@Model.Price.ToString("F2")</dd>

                    <dt>Discounted Price</dt>
                    <dd>@(Model.DiscountedPrice > 0 ? $"${Model.DiscountedPrice:F2}" : "No discounted price")</dd>

                    <dt>Image Count</dt>
                    <dd>@imageGallery.Count</dd>
                </dl>
            </article>

            <article class="admin-panel">
                <h2>Admin Notes</h2>
                <p class="admin-note">
                    This screen shows the current read-only product snapshot from the admin catalog. Use it to verify the
                    linked product record, confirm what price is effectively shown, review the stored image set, and spot
                    stock or promotion issues before making further administrative changes.
                </p>
            </article>
        </section>
    </div>
</div>
